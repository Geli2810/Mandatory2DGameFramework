<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>PlayMyGame</id>
    <version>1.0.0</version>
    <title>Play The Game</title>
    <authors>Geli28</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/Geli2810/Mandatory2DGameFramework</projectUrl>
    <description>This project is a turn-based 2D game framework designed for .NET 8. The framework allows you to create a world with creatures that can move, fight, and collect items such as weapons and armor. Each creature can have multiple attack and defense items, and battles are resolved by taking turns attacking each other. The system supports logging, configuration via XML, and uses several design patterns (such as Strategy, Observer, Template Method, Decorator, and Composite) to ensure flexibility and extensibility. The framework is intended as a foundation for building simple, console-based 2D games without a graphical user interface.</description>
    <releaseNotes>Summary of changes made in this release of the package.</releaseNotes>
    <copyright>Copyright © 2026 Geli28</copyright>
    <tags>C# .NET game framework turn-based 2D</tags>
  </metadata>
</package>